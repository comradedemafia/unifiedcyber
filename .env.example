# Supabase / Lovable Cloud (public values - safe to ship in the frontend bundle)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Application URLs - replace with your actual domain before deploying
VITE_APP_URL=https://yourdomain.com
VITE_TERMINAL_WS_URL=wss://yourdomain.com/terminal

# Terminal server runtime config (used by server/terminal-server.js)
# These can reuse the Supabase values above via fallbacks, or be set explicitly.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
TERMINAL_PORT=4000
TERMINAL_SHELL=/bin/bash
TERMINAL_ALLOWED_ROLES=admin,moderator

# Optional: ACME email for Let's Encrypt / Caddy TLS
ACME_EMAIL=you@example.com
